{
  "version": 2,
  "framework": "vite",
  "installCommand": "cd royal-blue-main/client && npm install",
  "buildCommand": "cd royal-blue-main/client && npm run build",
  "outputDirectory": "royal-blue-main/client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/enquiries"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
